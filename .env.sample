# GitHub API Credentials
GITHUB_TOKEN=your_github_token_here
GITHUB_ENTERPRISE=your_enterprise_slug_here
GITHUB_ORG=your_organization_slug_here

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/burnrate

# Notification channels (optional)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...
BUDGET_ISSUE_REPO=owner/repo

# Microsoft 365 (Outlook email via Graph API)
MS365_TENANT_ID=your_tenant_id
MS365_CLIENT_ID=your_client_id
MS365_CLIENT_SECRET=your_client_secret
NOTIFY_EMAIL_FROM=burnrate@company.com
NOTIFY_EMAIL_TO=platform-ops@company.com

# Escalation behavior
ALERT_RENOTIFY_HOURS=24
ALERT_ESCALATE_DAYS=3
